# ═══════════════════════════════════════════════════════════════
# FRONTEND (Next.js) - frontend/.env.local
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ═══════════════════════════════════════════════════════════════
# BACKEND (Express) - backend/.env.local
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# ────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION (NEW)
# ────────────────────────────────────────────────────────────────
JWT_SECRET=your_very_secure_jwt_secret_min_32_characters_long

# ────────────────────────────────────────────────────────────────
# CORS CONFIGURATION (NEW)
# ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ────────────────────────────────────────────────────────────────
# DATABASE - Scaleway PostgreSQL
# ────────────────────────────────────────────────────────────────
# Créer une DB sur https://console.scaleway.com/databases/postgresql

DB_HOST=xxxxx.pg.scw.cloud
DB_PORT=5432
DB_USER=default
DB_PASSWORD=your_password_here
DB_NAME=postgres
DB_SSL=true

# ────────────────────────────────────────────────────────────────
# OBJECT STORAGE - Scaleway S3
# ────────────────────────────────────────────────────────────────
# Créer un bucket sur https://console.scaleway.com/object-storage

SCALEWAY_ENDPOINT=https://s3.fr-par.scw.cloud
SCALEWAY_REGION=fr-par
SCALEWAY_BUCKET=legomnia-media
SCALEWAY_ACCESS_KEY=your_access_key
SCALEWAY_SECRET_KEY=your_secret_key
