# Enable GZIP Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
  AddOutputFilter DEFLATE svg
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 2592000 seconds"

  # Cache HTML pages for 1 hour
  ExpiresByType text/html "access plus 1 hour"

  # Cache CSS and JS for 1 year (versioned with query string)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"

  # Cache images for 1 year
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"

  # Cache fonts for 1 year
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# HTTP Security Headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "accelerometer=(), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=()"
</IfModule>

# Force HTTPS and www
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force www
  RewriteCond %{HTTP_HOST} ^legomnia.com [NC]
  RewriteRule ^(.*)$ https://www.legomnia.com%{REQUEST_URI} [L,R=301]
</IfModule>

# Prevent hotlinking of images/media
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?legomnia.com [NC]
  RewriteRule \.(jpg|jpeg|png|gif|svg|mp4|webm)$ - [NC,F,L]
</IfModule>

# Block access to hidden files/folders
<FilesMatch "^\.|^#.*#|~$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Block access to backend folders
<IfModule mod_authz_core.c>
  <DirectoryMatch "^/\.(git|svn|hg)">
    Require all denied
  </DirectoryMatch>
</IfModule>
